# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_DEPLOYMENT_CHAT=gpt-4o
AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# ── Azure AI Search ───────────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_API_KEY=<your-key>
AZURE_SEARCH_INDEX_FINANCE=finance-knowledge

# ── Microsoft Fabric / ADLS Gen2 ─────────────────────────────────────────────
FABRIC_WORKSPACE_ID=<your-workspace-id>
FABRIC_LAKEHOUSE_ID=<your-lakehouse-id>
ADLS_ACCOUNT_NAME=<your-storage-account>
ADLS_CONTAINER=finance-lakehouse
ADLS_CONNECTION_STRING=<your-connection-string>

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=change-me-in-production
CORS_ORIGINS=["http://localhost:3000"]

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=9090
